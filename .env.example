# QueueStorm Complaint Investigator — environment variable template.
#
# Copy this file to `.env` (which is gitignored) and fill in the values below.
# The service refuses to start unless PORT is set — there is no baked-in
# default so misconfiguration fails loudly at startup.

# Port to bind on. Required. Must be an integer in 1..65535.
PORT=8000

# The current build makes zero outbound calls and uses no models.
# The variables below are placeholders for future optional integrations.
#
# LLM_API_KEY=
# LLM_MODEL=
