# QueueStorm Complaint Investigator — environment variable template.
#
# Copy this file to `.env` (which is gitignored) and fill in any values you
# want to override. The service works with NO environment variables set.

# Port to bind on. Defaults to 3000.
# PORT=3000

# The current build makes zero outbound calls and uses no models.
# The variables below are placeholders for future optional integrations.
#
# LLM_API_KEY=
# LLM_MODEL=
